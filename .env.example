# Red CLI Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenAI API Key (GPT models)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenRouter API Key (Various open source models)
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Google Gemini API Key
GEMINI_API_KEY=your-gemini-key-here

# NVIDIA API Key (for models on NVIDIA NGC)
NVIDIA_API_KEY=nvapi-your-nvidia-key-here

# Brave Search API (for /web command)
BRAVE_SEARCH_API_KEY=your-brave-search-key-here

# Tavily Search API (alternative for /web command)
TAVILY_API_KEY=your-tavily-key-here

# UI Theme (dark, light, minimal)
RED_THEME=dark

# Editor to use for /prompt command
EDITOR=vim

# Custom blocked commands (comma-separated)
# RED_BLOCKED_COMMANDS=rm -rf /,mkfs,dd if=

# Enable debug mode
# DEBUG=false